<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Examen cultura generala - Proiect" Height="500" Width="700"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        WindowStyle="ThreeDBorderWindow">

    <Window.Resources>
        <SolidColorBrush x:Key="CuloareFundal" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="CuloareText"   Color="#2C3E50"/>
        <SolidColorBrush x:Key="CuloareVerde"  Color="#27AE60"/>
        <SolidColorBrush x:Key="CuloareGri"    Color="#BDC3C7"/>
        <SolidColorBrush x:Key="CuloareRosie"    Color="#E74C3C"/>
    </Window.Resources>

    <Grid Background="{StaticResource CuloareFundal}">
        <Button x:Name="btnMeniuCauta" 
                Content="_Cauta" 
                HorizontalAlignment="Left"
                VerticalAlignment="Top" 
                Width="80"
                Height="40" 
                Margin="10" 
                Background="{StaticResource CuloareRosie}" 
                Foreground="White" 
                Click="btnMeniuCauta_Click"/>

        <Grid x:Name="panelAdauga" 
              Visibility="Visible">
            <StackPanel 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center" 
                Width="350">
                <Label x:Name="Examen" 
                       FontSize="26" 
                       FontWeight="SemiBold" 
                       Foreground="{StaticResource CuloareText}" 
                       HorizontalContentAlignment="Center" 
                       Margin="0,0,0,20"/>

                <Label x:Name="lblNumeMaterie" 
                       Content="Alege materia" 
                       FontSize="13" Foreground="{StaticResource CuloareText}"/>
                <StackPanel x:Name="panelMaterii" 
                            Margin="0,0,0,15">
                    <RadioButton x:Name="rbIstorie" 
                                 Content="Istorie" 
                                 GroupName="Materii"
                                 IsChecked="True" Margin="5"/>
                    <RadioButton x:Name="rbGeografie" 
                                 Content="Geografie" 
                                 GroupName="Materii" 
                                 Margin="5"/>
                    <RadioButton x:Name="rbBiologie"
                                 Content="Biologie" 
                                 GroupName="Materii"
                                 Margin="5"/>
                    <RadioButton x:Name="rbInformatica"
                                 Content="Informatica" 
                                 GroupName="Materii" 
                                 Margin="5"/>
                    <RadioButton x:Name="rbMatematica"
                                 Content="Matematica"
                                 GroupName="Materii" 
                                 Margin="5"/>
                </StackPanel>

                <Label x:Name="lblDificultate" 
                       Content="Dificultate (1-3)" 
                       FontSize="13" Foreground="{StaticResource CuloareText}"/>
                <StackPanel Grid.Row="3"
                             Orientation="Horizontal" 
                             Margin="2,0,0,6">
                    <TextBlock Text="1 Usor"   
                                Foreground="#27AE60" 
                                FontSize="11" 
                                FontFamily="Segoe UI"
                                FontWeight="SemiBold" 
                                Margin="0,0,12,0"/>
                    <TextBlock Text="2 Mediu"  
                                Foreground="#E67E22" 
                                FontSize="11" 
                                FontFamily="Segoe UI" 
                                FontWeight="SemiBold" 
                                Margin="0,0,12,0"/>
                    <TextBlock Text="3 Greu"   
                                Foreground="#E74C3C" 
                                FontSize="11" 
                                FontFamily="Segoe UI" 
                                FontWeight="SemiBold"/>
                </StackPanel>
                <TextBox 
                    x:Name="txtDificultate"
                    Height="32" 
                    TextChanged="txtDificultate_TextChanged"/>
                <TextBlock x:Name="errDificultate" 
                           Text="" Foreground="Red" 
                           Visibility="Collapsed" 
                           FontSize="10"/>

                <StackPanel 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="0,20,0,0">
                    <Button x:Name="btnSalveaza" 
                            Content="_Salveaza" 
                            Width="100" 
                            Height="34"
                            Background="{StaticResource CuloareVerde}" 
                            Foreground="White" 
                            Click="btnSalveaza_Click"/>
                    <Button x:Name="btnReset"
                            Content="_Reset"
                            Width="80" Height="34"
                            Background="{StaticResource CuloareGri}" 
                            Margin="10,0"
                            Click="btnReset_Click"/>
                    <Button x:Name="btnIncepeTest"
                            Content="_Incepe Test" 
                            Width="100" 
                            Height="34" 
                            Background="#3498DB" 
                            Foreground="White" 
                            Click="btnIncepeTest_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid x:Name="panelCauta" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center" 
                        Width="450">
                <Label Content="Cauta dupa nume materie:" 
                       Foreground="{StaticResource CuloareText}"/>
                <TextBox x:Name="txtCautaNume" 
                         Height="32" 
                         Margin="0,5"/>

                <Label Content="Selectează dificultatea:" 
                       Margin="0,10,0,5"/>
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Margin="0,0,0,15">
                    <RadioButton x:Name="rbCautaUsor" 
                                 Content="1 Usor" 
                                 Margin="10,0"
                                 IsChecked="True"/>
                    <RadioButton x:Name="rbCautaMediu"
                                 Content="2 Mediu"
                                 Margin="10,0"/>
                    <RadioButton x:Name="rbCautaGreu" 
                                 Content="3 Greu" 
                                 Margin="10,0"/>
                </StackPanel>

                <Button x:Name="btnAfisare"
                        Content="_Afisare Intrebari" 
                        Height="35"
                        Background="{StaticResource CuloareVerde}"
                        Foreground="White"
                        Click="btnAfisare_Click"/>

                <ListBox x:Name="lstRezultate" 
                         Height="200" 
                         Margin="0,15,0,0" 
                         Background="White" 
                         BorderBrush="{StaticResource CuloareGri}"/>

                <Button Content="Inapoi" 
                        Margin="0,20,0,0" 
                        Height="40"
                        Background="#283Ae4" 
                        Foreground="White"
                        Click="btnInapoi_Click" />
            </StackPanel>
        </Grid>

        <Grid x:Name="panelTest" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="500">
                <TextBlock x:Name="lblTitluTest" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,20" 
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="lblTextIntrebare" 
                           TextWrapping="Wrap"
                           FontSize="16" 
                           Margin="0,0,0,20"/>

                <RadioButton x:Name="rbA" GroupName="Raspunsuri" Margin="5"/>
                <RadioButton x:Name="rbB" GroupName="Raspunsuri" Margin="5"/>
                <RadioButton x:Name="rbC" GroupName="Raspunsuri" Margin="5"/>
                <RadioButton x:Name="rbD" GroupName="Raspunsuri" Margin="5"/>

                <Button Content="Trimite Raspuns"
                        Margin="0,20,0,0"
                        Height="40" 
                        Background="#27AE60" 
                        Foreground="White"
                        Click="btnTrimiteRaspuns_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>